# Copy this file to .env and fill in your values.
# .env is git-ignored and should never be committed.

# ── MongoDB ──────────────────────────────────────────────────────────────────
# The OLAP pipeline uses MongoDB Change Streams, which require a Replica Set.
# Choose the connection string that matches your runtime:
#
# 1. Docker Compose (docker compose up):
#    Set automatically by docker-compose.yml — do not override here.
#
# 2. pnpm dev (no Docker):
#    Leave MONGODB_URI unset. The server starts an in-process MongoMemoryReplSet
#    automatically (requires no additional setup).
#
# 3. Local mongod with RS (advanced):
#    Start mongod: mongod --replSet rs0 --dbpath /tmp/rs0
#    Init RS once: mongosh --eval "rs.initiate({_id:'rs0',members:[{_id:0,host:'localhost:27017'}]})"
#    Then set:
#    MONGODB_URI=mongodb://localhost:27017/teacher_erp?replicaSet=rs0&directConnection=true
#
# 4. MongoDB Atlas (production / cloud dev):
#    Create a free M0 cluster at cloud.mongodb.com (supports Change Streams).
#    Allowlist your IP, create a DB user, then set:
#    MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/teacher_erp
#
# MONGODB_URI=

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. Change this to a long random string before deploying.
# JWT_SECRET=change-me-to-a-long-random-string

# Access-token lifetime in seconds (default: 3600 = 1 hour).
# AUTH_TOKEN_TTL_SECONDS=3600

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=3001
# CLIENT_ORIGIN=http://localhost:5173

# ── Client (Vite) ────────────────────────────────────────────────────────────
# Base URL the browser uses when making API calls to the server.
# VITE_API_BASE_URL=http://localhost:3001

# ── Runtime ──────────────────────────────────────────────────────────────────
# NODE_ENV=development
