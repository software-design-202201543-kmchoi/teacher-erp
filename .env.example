# Copy this file to .env and fill in your values.
# .env is git-ignored and should never be committed.

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Used by the server to connect to MongoDB.
# When running via Docker Compose this is set automatically; override only if
# you are pointing at a remote Atlas cluster or a different local instance.
# MONGODB_URI=mongodb://mongo:27017/teacher_erp

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. Change this to a long random string before deploying.
# JWT_SECRET=change-me-to-a-long-random-string

# Access-token lifetime in seconds (default: 3600 = 1 hour).
# AUTH_TOKEN_TTL_SECONDS=3600

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=3001
# CLIENT_ORIGIN=http://localhost:5173

# ── Client (Vite) ────────────────────────────────────────────────────────────
# Base URL the browser uses when making API calls to the server.
# VITE_API_BASE_URL=http://localhost:3001

# ── Runtime ──────────────────────────────────────────────────────────────────
# NODE_ENV=development
