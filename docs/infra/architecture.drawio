        <mxCell id="atlas-box" value="MongoDB Atlas  ·  AWS ap-northeast-2&lt;br/&gt;PrivateLink (planned — Phase 3)" style="swimlane;html=1;startSize=30;fillColor=#e8f5e9;strokeColor=#2e7d32;fontStyle=1;fontSize=10;" vertex="1" parent="zone-external">
          <mxGeometry x="20" y="80" width="250" height="380" as="geometry" />
        </mxCell>

