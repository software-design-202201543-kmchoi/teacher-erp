        <mxCell id="rs-primary" value="&lt;b&gt;PRIMARY&lt;/b&gt;&lt;br/&gt;:27017&lt;br/&gt;reads + writes&lt;br/&gt;oplog source" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.documentdb;html=1;labelBackgroundColor=none;sketch=0;fontStyle=0;fontSize=9;fillColor=#00684A;strokeColor=none;fontColor=#ffffff;labelPosition=center;align=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="atlas-box">
