        <mxCell id="cloudwatch" value="&lt;b&gt;CloudWatch&lt;/b&gt;&lt;br/&gt;Logs 30일 보존&lt;br/&gt;메트릭 · 알람" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch;html=1;labelBackgroundColor=none;sketch=0;fontStyle=1;fontSize=9;fillColor=#E7157B;strokeColor=none;fontColor=#ffffff;labelPosition=center;align=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="zone-mgmt">
          <mxGeometry x="480" y="60" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="dynamo" value="&lt;b&gt;DynamoDB&lt;/b&gt;&lt;br/&gt;teacher-erp-tflock&lt;br/&gt;(Terraform state lock)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;html=1;labelBackgroundColor=none;sketch=0;fontStyle=1;fontSize=9;fillColor=#3F8624;strokeColor=none;fontColor=#ffffff;labelPosition=center;align=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="zone-mgmt">
          <mxGeometry x="700" y="60" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s3tfstate" value="&lt;b&gt;S3&lt;/b&gt;&lt;br/&gt;teacher-erp-tfstate&lt;br/&gt;(Terraform state)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;html=1;labelBackgroundColor=none;sketch=0;fontStyle=1;fontSize=9;fillColor=#3F8624;strokeColor=none;fontColor=#ffffff;labelPosition=center;align=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="zone-mgmt">
          <mxGeometry x="840" y="60" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- LEGEND                                                          -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <mxCell id="legend" value="&lt;b&gt;⚠ EKS 미사용&lt;/b&gt; — ECS Fargate 선택 이유:&lt;br/&gt;EKS 컨트롤 플레인 비용 $73/월 절감,&lt;br/&gt;쿠버네티스 운영 복잡도 제거.&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;비용 (예상 ~$56–63/월)&lt;/b&gt;&lt;br/&gt;ECS Fargate Spot: ~$5–10&lt;br/&gt;ALB: ~$16  ·  NAT GW: ~$30&lt;br/&gt;CloudFront+S3: ~$1–3  ·  CW: ~$3&lt;br/&gt;&lt;hr/&gt;&lt;b&gt;개발 환경&lt;/b&gt;&lt;br/&gt;Docker Compose: mongo (single-node RS rs0)&lt;br/&gt;+ server :3001 + client :5173" style="text;html=1;strokeColor=#999;fillColor=#f5f5f5;align=left;verticalAlign=top;spacingLeft=8;spacingRight=8;overflow=hidden;fontSize=11;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="30" y="760" width="380" height="170" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- EDGES                                                           -->
        <!-- ══════════════════════════════════════════════════════════════ -->

        <!-- Browser → CloudFront -->
        <mxCell id="e1" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0066CC;fontColor=#0066CC;fontStyle=1;endArrow=block;endFill=1;" edge="1" source="browser" target="cloudfront" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CloudFront → S3 -->
        <mxCell id="e2" value="/* static" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#3F8624;fontColor=#3F8624;fontStyle=1;" edge="1" source="cloudfront" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CloudFront → ALB -->
        <mxCell id="e3" value="/api/*" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#8C4FFF;fontColor=#8C4FFF;fontStyle=1;" edge="1" source="cloudfront" target="alb" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ACM → CloudFront -->
        <mxCell id="e4" value="TLS cert" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#DD344C;fontColor=#DD344C;dashed=1;" edge="1" source="acm" target="cloudfront" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ALB → Express -->
        <mxCell id="e5" value="HTTP :3001" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#e65100;fontColor=#e65100;fontStyle=1;" edge="1" source="alb" target="express" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Express → MongoDB Primary -->
        <mxCell id="e6" value="TCP 27017&lt;br/&gt;Change Streams&lt;br/&gt;(PrivateLink)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#00684A;fontColor=#00684A;fontStyle=1;" edge="1" source="express" target="rs-primary" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Express → SSM -->
        <mxCell id="e7" value="fetch secrets" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E7157B;fontColor=#E7157B;dashed=1;" edge="1" source="express" target="ssm" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Express → CloudWatch -->
        <mxCell id="e8" value="logs / metrics" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#E7157B;fontColor=#E7157B;dashed=1;" edge="1" source="express" target="cloudwatch" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Express → NAT (outbound internet) -->
        <mxCell id="e9" value="outbound" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;dashed=1;" edge="1" source="express" target="nat" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- GitHub → GHA -->
        <mxCell id="e10" value="push" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;" edge="1" source="github" target="gha" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- GHA → ECR -->
        <mxCell id="e11" value="docker push" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#ED7100;fontColor=#ED7100;fontStyle=1;" edge="1" source="gha" target="ecr" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- GHA → S3 (static deploy) -->
        <mxCell id="e12" value="s3 sync" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#3F8624;fontColor=#3F8624;fontStyle=1;" edge="1" source="gha" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- GHA → CloudFront invalidate -->
        <mxCell id="e13" value="invalidate" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#8C4FFF;fontColor=#8C4FFF;dashed=1;" edge="1" source="gha" target="cloudfront" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- GHA → ECS (update-service) -->
        <mxCell id="e14" value="ecs update-service" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#e65100;fontColor=#e65100;fontStyle=1;" edge="1" source="gha" target="ecs-task-box" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ECR → ECS (pull image) -->
