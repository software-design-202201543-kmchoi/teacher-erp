        <mxCell id="ecr" value="&lt;b&gt;Amazon ECR&lt;/b&gt;&lt;br/&gt;server:{sha}&lt;br/&gt;client:{sha}" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ecr;html=1;labelBackgroundColor=none;sketch=0;fontStyle=1;fontSize=9;fillColor=#ED7100;strokeColor=none;fontColor=#ffffff;labelPosition=center;align=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="zone-mgmt">
          <mxGeometry x="40" y="60" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ssm" value="&lt;b&gt;SSM Parameter Store&lt;/b&gt;&lt;br/&gt;MONGODB_URI (SecureString)&lt;br/&gt;JWT_SECRET (SecureString)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.systems_manager_parameter_store;html=1;labelBackgroundColor=none;sketch=0;fontStyle=1;fontSize=9;fillColor=#E7157B;strokeColor=none;fontColor=#ffffff;labelPosition=center;align=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="zone-mgmt">
