        <mxCell id="gha" value="&lt;b&gt;GitHub Actions&lt;/b&gt;&lt;br/&gt;OIDC Auth (no long-lived keys)&lt;br/&gt;① docker build + push ECR&lt;br/&gt;② vite build + s3 sync&lt;br/&gt;③ ecs update-service&lt;br/&gt;④ CF invalidation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="zone-cicd">
