          <mxGeometry x="20" y="190" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Secondary 2 -->
        <mxCell id="rs-secondary2" value="&lt;b&gt;SECONDARY&lt;/b&gt;&lt;br/&gt;:27017&lt;br/&gt;oplog replica" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.documentdb;html=1;labelBackgroundColor=none;sketch=0;fontStyle=0;fontSize=9;fillColor=#1a7a4a;strokeColor=none;fontColor=#ffffff;labelPosition=center;align=center;verticalLabelPosition=bottom;verticalAlign=top;" vertex="1" parent="atlas-box">
          <mxGeometry x="155" y="190" width="60" height="60" as="geometry" />
        </mxCell>

