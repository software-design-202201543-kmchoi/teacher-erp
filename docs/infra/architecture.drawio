          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Change Streams note -->
        <mxCell id="cs-note" value="Change Streams require oplog&lt;br/&gt;→ Replica Set mandatory&lt;br/&gt;(standalone 불가)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=9;" vertex="1" parent="atlas-box">
