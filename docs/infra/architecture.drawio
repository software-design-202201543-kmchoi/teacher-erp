        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- PRIVATE SUBNET — ECS Fargate                                    -->
        <!-- ══════════════════════════════════════════════════════════════ -->

        <!-- ECS Cluster outer box -->
        <mxCell id="ecs-cluster-box" value="ECS Fargate Cluster  (NOT EKS — no k8s control plane)" style="swimlane;startSize=24;fillColor=#fff3e0;strokeColor=#e65100;fontStyle=1;fontSize=10;" vertex="1" parent="zone-private">
          <mxGeometry x="30" y="40" width="490" height="220" as="geometry" />
        </mxCell>

        <!-- ECS Task box -->
        <mxCell id="ecs-task-box" value="ECS Fargate Task  ·  0.25 vCPU / 512 MB  ·  Spot 75% + On-Demand 25%" style="swimlane;startSize=22;fillColor=#ffe0b2;strokeColor=#e65100;fontStyle=0;fontSize=9;" vertex="1" parent="ecs-cluster-box">
          <mxGeometry x="20" y="40" width="450" height="155" as="geometry" />
        </mxCell>

        <!-- Express server node -->
        <mxCell id="express" value="&lt;b&gt;Express 5 Server&lt;/b&gt;&lt;br/&gt;Node 20 · ESM · Port 3001&lt;br/&gt;━━━━━━━━━━━━━━━━━━&lt;br/&gt;/api/auth   · /api/students&lt;br/&gt;/api/grades  · /api/feedback&lt;br/&gt;/api/counseling · /api/reports&lt;br/&gt;/api/notifications (SSE)&lt;br/&gt;/api/analytics  · /api/audit&lt;br/&gt;/api/search · /api/admin&lt;br/&gt;━━━━━━━━━━━━━━━━━━&lt;br/&gt;Middleware: accessLog → CORS&lt;br/&gt;→ authenticate (JWT) → authorize (CASL)&lt;br/&gt;━━━━━━━━━━━━━━━━━━&lt;br/&gt;OLAP Worker: MongoDB Change Streams&lt;br/&gt;(grades / feedback / counseling)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=9;align=left;spacingLeft=8;verticalAlign=top;" vertex="1" parent="ecs-task-box">
          <mxGeometry x="10" y="30" width="260" height="110" as="geometry" />
        </mxCell>

        <!-- Container image label -->
        <mxCell id="ecr-ref" value="&lt;b&gt;ECR Image&lt;/b&gt;&lt;br/&gt;server:{git-sha}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ED7100;fontSize=9;" vertex="1" parent="ecs-task-box">
          <mxGeometry x="290" y="30" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- SSE annotation -->
        <mxCell id="sse-note" value="SSE: in-process pub/sub&lt;br/&gt;Map{userId, Set{Response}}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=9;" vertex="1" parent="ecs-task-box">
          <mxGeometry x="290" y="95" width="130" height="45" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════════ -->
